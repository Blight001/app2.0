{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "skipLibCheck": true,
    "target": "es2022",
    "module": "preserve",
    "resolveJsonModule": true,
    "strict": false
  },
  "include": ["src/app/main/**/*.js", "src/app/shared/**/*.js", "scripts/**/*.js"],
  "exclude": ["node_modules", "appbuild", "src/assets"]
}
