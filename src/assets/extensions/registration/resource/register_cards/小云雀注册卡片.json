{
  "name": "小云雀注册卡片",
  "website": "https://www.pippit.ai/zh-cn",
  "description": "香蕉AI工具自动注册，使用标准步骤流程",
  "email": "",
  "password": "",
  "points": 0,
  "random": {
    "email": {
      "length": 10,
      "type": "mixed"
    },
    "password": {
      "length": 12,
      "type": "mixed"
    }
  },
  "steps": [
    {
      "name": "访问小云雀页面",
      "type": "navigate",
      "url": "https://www.pippit.ai/zh-cn?",
      "wait": 3,
      "timeout": 60000
    },
    {
      "name": "点击登录按钮",
      "type": "loop_click",
      "by": "css_selector",
      "selector": "span:has-text('登录')",
      "timeout": 30000,
      "interval": 1000,
      "max_loop_attempts": 30,
      "stop_by": "css_selector",
      "stop_selector": "span:has-text('用电子邮箱登录')",
      "fallback_selectors": [
        "span:has-text('Log in')",
        "span:has-text('Sign in')",
        "button:has-text('登录')",
        "button:has-text('Log in')",
        "button:has-text('Sign in')",
        "[data-testid*='login']",
        "[data-testid*='sign']"
      ],
      "text_match": "Log in"
    },
    {
      "name": "用电子邮箱登录",
      "type": "click",
      "by": "css_selector",
      "selector": "span:has-text('用电子邮箱登录')",
      "wait": 2,
      "force_click": true,
      "text_match": "用电子邮箱登录",
      "fallback_selectors": [
        "span.lv_new_third_part_sign_in_expand-label:has-text('用电子邮箱登录')",
        "[data-testid*='email']:has-text('用电子邮箱登录')",
        "div:has-text('用电子邮箱登录')",
        "button:has-text('用电子邮箱登录')",
        "[role='button']:has-text('用电子邮箱登录')"
      ]
    },
    {
      "name": "注册",
      "type": "click",
      "by": "css_selector",
      "selector": "span:has-text('注册')",
      "timeout": 30000,
      "wait": 2,
      "max_retries": 5,
      "retry_delay": 1,
      "fallback_selectors": [
        "button:has-text('注册')",
        "a:has-text('注册')",
        "[role='button']:has-text('注册')",
        ".signupSwitch_signup_link",
        "[class*='signup']"
      ],
      "text_match": "注册"
    },
    {
      "name": "输入邮箱",
      "type": "type",
      "by": "css_selector",
      "selector": "input[placeholder='输入邮箱']",
      "text": "{account}@heysure.top",
      "timeout": 20000,
      "wait": 1
    },
    {
      "name": "输入密码",
      "type": "type",
      "by": "css_selector",
      "selector": "input[placeholder='输入密码']",
      "text": "{password}",
      "timeout": 20000,
      "wait": 1
    },
    {
      "name": "点击继续按钮",
      "type": "click",
      "by": "css_selector",
      "selector": "span:has-text('继续')",
      "wait": 3
    },
    {
      "name": "开始等待邮箱验证码",
      "type": "wait_verification_code",
      "email": "{email}",
      "timeout": 300,
      "max_retries": 2,
      "retry_count": 0
    },
    {
      "name": "填写验证码",
      "type": "type",
      "by": "css_selector",
      "selector": "input[maxlength='6']",
      "text": "{code}",
      "timeout": 60000,
      "wait": 2,
      "fallback_selectors": [
        "div.verification_code_input-number.verification_code_input-number-focus",
        "input[placeholder*='验证码']",
        "input[placeholder*='code']"
      ]
    },
    {
      "name": "填写出生年份",
      "type": "type",
      "by": "css_selector",
      "selector": "input[placeholder='年']",
      "text": "2000",
      "wait": 1
    },
    {
      "name": "选择出生月份",
      "type": "click",
      "by": "css_selector",
      "selector": ".lv-select-view-value:has-text('月')",
      "timeout": 30000,
      "max_retries": 5,
      "retry_delay": 2,
      "force_click": true,
      "fallback_selectors": [
        "span.lv-select-view-value-mirror:has-text('月')",
        "span[class*='select']:has-text('月')",
        "[placeholder*='月']"
      ],
      "text_match": "月"
    },
    {
      "name": "选择1月",
      "type": "click",
      "by": "css_selector",
      "selector": "li.lv-select-option:first-child",
      "timeout": 30000,
      "max_retries": 5,
      "retry_delay": 1,
      "fallback_selectors": [
        "li[role='option'][aria-selected='false']:has-text('1 月')",
        ".lv-select-option:has-text('1 月')",
        "li:has-text('1 月'):nth-of-type(1)"
      ],
      "text_match": "1 月"
    },
    {
      "name": "选择出生日期",
      "type": "click",
      "by": "css_selector",
      "selector": ".lv-select-view-value:has-text('日')",
      "timeout": 30000,
      "max_retries": 5,
      "retry_delay": 1,
      "force_click": true,
      "fallback_selectors": [
        "span.lv-select-view-value-mirror:has-text('日')",
        "span[class*='select']:has-text('日')",
        "[placeholder*='日']"
      ],
      "text_match": "日"
    },
    {
      "type": "wait",
      "name": "等待加载",
      "seconds": 0.5
    },
    {
      "name": "选择1日",
      "type": "click",
      "by": "css_selector",
      "selector": "li.lv-select-option:first-child",
      "timeout": 30000,
      "max_retries": 8,
      "retry_delay": 1,
      "force_click": true,
      "fallback_selectors": [
        "li[role='option'][aria-selected='false']:has-text('1')",
        ".lv-select-option:has-text('1')",
        "li:has-text('1'):nth-of-type(1)"
      ],
      "text_match": "1"
    },
    {
      "name": "等待下一步按钮消失",
      "type": "wait",
      "by": "css_selector",
      "wait_for_element_hidden": ".lv_new_sign_in_panel_wide-birthday-next",
      "wait_for_element_hidden_timeout_ms": 50000,
      "wait_for_element_hidden_interval_ms": 300
    },
    {
      "name": "点击重试按钮",
      "type": "click",
      "by": "css_selector",
      "selector": "button:has-text('重试')",
      "timeout": 1000,
      "optional": true,
      "force_click": true,
      "fallback_selectors": [
        "[role='button']:has-text('重试')",
        "span:has-text('重试')",
        "text=重试"
      ],
      "text_match": "重试"
    },
    {
      "name": "获取积分数",
      "type": "get_credits",
      "selector": "span[class*='credits-label']",
      "by": "css_selector",
      "timeout": 30000,
      "wait_for_credit_increase": true,
      "default": "0",
      "wait_for_credit_increase_timeout_ms": 5000,
      "wait_for_credit_increase_interval_ms": 500,
      "fallback_selectors": [
        "span[class*='credits-label']",
        "[class*='credits'] span"
      ]
    }
  ],
  "popups": [],
  "upload_server_url": "http://146.196.81.140:58158",
  "upload_card_key": "E1C0-8HAP-GC08-Q3PW-EV11",
  "min_cookie_size_bytes": 8000,
  "upload_target_score_scope": "all",
  "upload_target_score_types": [],
  "upload_target_score_type": "",
  "upload": {
    "server_url": "http://146.196.81.140:58158",
    "card_key": "E1C0-8HAP-GC08-Q3PW-EV11",
    "target_score_scope": "all",
    "target_score_types": [],
    "target_score_type": ""
  }
}
