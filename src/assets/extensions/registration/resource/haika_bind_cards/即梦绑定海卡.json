      ],
      "wait_timeout_ms": 15000,
      "wait_poll_interval_ms": 200
    },
    {
      "name": "点击登录",
      "type": "click",
      "by": "css_selector",
      "selector": "button:has-text('Sign in')",
      "fallback_selectors": [
        "span:has-text('Sign in')",
        "text=Sign in"
      ],
      "timeout": 30000,
      "force_click": true,
      "wait": 0,
      "click_attempt_timeout_ms": 5000,
      "skip_page_sync": true
    },
    {
      "name": "选择邮箱登录",
      "type": "click",
      "preferred_page_contains": [
        "dreamina.capcut.com/ai-tool/home"
      ],
      "by": "css_selector",
      "selector": "button:has-text('Continue with email')",
      "fallback_selectors": [
        "span:has-text('Continue with email')",
