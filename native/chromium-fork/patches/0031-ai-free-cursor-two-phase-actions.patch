+void OnResolvedActionTarget(content::GlobalRenderFrameHostId frame_id,
+                            std::string action,
+                            AiFreeAutomationSuccess success,
+                            AiFreeAutomationFailure failure,
+                            base::Value value) {
+  const base::DictValue* result = value.GetIfDict();
+  const base::DictValue* input =
+      result ? result->FindDict("nativeInput") : nullptr;
+  content::RenderFrameHost* frame = content::RenderFrameHost::FromID(frame_id);
+  content::WebContents* contents =
+      frame ? content::WebContents::FromRenderFrameHost(frame) : nullptr;
+  if (!result || !result->FindBool("success").value_or(false) || !input ||
+      !contents) {
+    return result ? std::move(success).Run(result->Clone())
+                  : Fail(std::move(failure), "ACTION_RESULT_INVALID",
+                         "页面动作未返回可提交的坐标");
+  }
+  const std::optional<double> x = input->FindDouble("x");
+  const std::optional<double> y = input->FindDouble("y");
+  const std::optional<double> width = input->FindDouble("viewportWidth");
+  const std::optional<double> height = input->FindDouble("viewportHeight");
+  const gfx::Rect bounds = contents->GetContainerBounds();
+  if (!x || !y || !width || !height || *width <= 0 || *height <= 0 ||
+      bounds.IsEmpty()) {
+    return Fail(std::move(failure), "INPUT_TARGET_UNAVAILABLE",
+                "Chromium 原生输入目标不可用");
+  }
+  content::RenderWidgetHostView* view = contents->GetRenderWidgetHostView();
+  if (!view) {
+    return Fail(std::move(failure), "SCREEN_COORDINATE_UNAVAILABLE",
+                "无法把 Chromium 提交坐标转换到根窗口");
+  }
+  const gfx::PointF root_point = view->TransformPointToRootCoordSpaceF(
+      gfx::PointF(static_cast<float>(*x * bounds.width() / *width),
+                  static_cast<float>(*y * bounds.height() / *height)));
+  const gfx::Rect view_bounds = view->GetViewBounds();
+  display::Screen* display_screen = display::Screen::Get();
+  if (!display_screen || view_bounds.IsEmpty()) {
+    return Fail(std::move(failure), "SCREEN_COORDINATE_UNAVAILABLE",
+                "无法把 Chromium 提交坐标转换为物理屏幕坐标");
+  }
+  const gfx::Point dip_point(
+      static_cast<int>(std::lround(view_bounds.x() + root_point.x())),
+      static_cast<int>(std::lround(view_bounds.y() + root_point.y())));
+  const gfx::Rect physical = display_screen->DIPToScreenRectInWindow(
+      contents->GetTopLevelNativeWindow(),
+      gfx::Rect(dip_point, gfx::Size(1, 1)));
+  base::DictValue target;
+  target.Set("x", physical.x());
+  target.Set("y", physical.y());
+  base::DictValue response = result->Clone();
+  response.Remove("nativeInput");
+  response.Set("targetPhysical", std::move(target));
+  response.Set("resolvedInput", input->Clone());
+  response.Set("action", action);
+  std::move(success).Run(std::move(response));
+}
+
+void CommitResolvedAction(content::WebContents* contents,
+                          const base::DictValue& command,
+                          AiFreeAutomationSuccess success,
+                          AiFreeAutomationFailure failure) {
+  const std::string* action_value = command.FindString("action");
+  const std::string action = action_value ? *action_value : "";
+  const base::DictValue* input = command.FindDict("resolvedInput");
+  if (!input) {
+    Fail(std::move(failure), "INPUT_TARGET_UNAVAILABLE",
+         "两阶段动作缺少有效提交坐标");
+    return;
+  }
+  base::DictValue resolved;
+  resolved.Set("nativeInput", input->Clone());
+  base::DictValue response;
+  response.Set("success", true);
+  response.Set("action", action);
+  DispatchResolvedMouse(
+      contents, resolved, action,
+      base::BindOnce(&OnMouseDispatched, std::move(success),
+                     std::move(failure), std::move(response)));
+}
