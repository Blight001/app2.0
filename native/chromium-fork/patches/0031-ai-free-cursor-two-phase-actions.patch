+++ b/chrome/browser/ui/views/frame/ai_free_mouse_input.cc
@@ -0,0 +1,70 @@
+// Copyright 2026 AI-FREE Authors. All rights reserved.
+
+#include "chrome/browser/ui/views/frame/ai_free_mouse_input.h"
+
+#include <algorithm>
+
+#include "content/public/browser/render_frame_host.h"
+#include "content/public/browser/render_widget_host.h"
+#include "content/public/browser/render_widget_host_view.h"
+#include "content/public/browser/web_contents.h"
+#include "third_party/blink/public/common/input/web_input_event.h"
+#include "third_party/blink/public/common/input/web_mouse_event.h"
+#include "ui/events/event_utils.h"
+#include "ui/gfx/geometry/rect.h"
+
+namespace {
+
+blink::WebMouseEvent MouseEvent(blink::WebInputEvent::Type type,
+                                blink::WebMouseEvent::Button button,
+                                int modifiers,
+                                int clicks,
+                                const gfx::PointF& point,
+                                const gfx::Rect& bounds) {
+  blink::WebMouseEvent event(type, modifiers, ui::EventTimeForNow());
+  event.button = button;
+  event.click_count = clicks;
+  event.pointer_type = blink::WebPointerProperties::PointerType::kMouse;
+  event.SetPositionInWidget(point.x(), point.y());
+  event.SetPositionInScreen(bounds.x() + point.x(),
+                            bounds.y() + point.y());
+  return event;
+}
+
+}  // namespace
+
+void DispatchAiFreeMouseInput(content::WebContents* web_contents,
+                              const gfx::PointF& target,
+                              bool right_button,
+                              int click_count,
+                              base::OnceCallback<void(bool)> callback) {
+  content::RenderFrameHost* frame =
+      web_contents ? web_contents->GetPrimaryMainFrame() : nullptr;
+  content::RenderWidgetHost* widget =
+      frame ? frame->GetRenderWidgetHost() : nullptr;
+  if (!widget || !widget->GetView()) {
+    return std::move(callback).Run(false);
+  }
+  const gfx::Rect bounds = web_contents->GetContainerBounds();
+  const auto button = right_button
+      ? blink::WebMouseEvent::Button::kRight
+      : blink::WebMouseEvent::Button::kLeft;
+  const int count = std::clamp(click_count, 1, 2);
+  const int down_modifiers = blink::WebInputEvent::kFromDebugger |
+      (right_button ? blink::WebInputEvent::kRightButtonDown
+                    : blink::WebInputEvent::kLeftButtonDown);
+  widget->Focus();
+  widget->ForwardMouseEvent(MouseEvent(
+      blink::WebInputEvent::Type::kMouseMove,
+      blink::WebMouseEvent::Button::kNoButton,
+      blink::WebInputEvent::kFromDebugger, 0, target, bounds));
+  for (int index = 1; index <= count; ++index) {
+    widget->ForwardMouseEvent(MouseEvent(
+        blink::WebInputEvent::Type::kMouseDown, button, down_modifiers,
+        index, target, bounds));
+    widget->ForwardMouseEvent(MouseEvent(
+        blink::WebInputEvent::Type::kMouseUp, button,
+        blink::WebInputEvent::kFromDebugger, index, target, bounds));
+  }
+  std::move(callback).Run(true);
+}
