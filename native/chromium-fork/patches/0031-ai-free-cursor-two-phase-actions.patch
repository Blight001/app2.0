-class PointerSession : public content::WebContentsObserver,
-                       public views::ViewObserver {
- public:
-  explicit PointerSession(content::WebContents* contents)
-      : content::WebContentsObserver(contents), observed_contents_(contents) {}
-
-  ~PointerSession() override { DetachOverlay(); }
-
-  void Start(const gfx::PointF& target,
-             bool right_button,
-             int click_count,
-             base::OnceCallback<void(bool)> callback) {
-    Finish(false);
-    hide_timer_.Stop();
-    target_ = target;
-    right_button_ = right_button;
-    click_count_ = std::clamp(click_count, 1, 2);
-    completed_clicks_ = 0;
-    callback_ = std::move(callback);
-    if (!AttachOverlay()) {
-      return Finish(false);
-    }
-    if (!has_position_) {
-      position_ = gfx::PointF(std::max(8.0f, target.x() - 72.0f),
-                              std::max(8.0f, target.y() - 48.0f));
-    }
-    start_ = position_;
-    const float distance = (target_ - start_).Length();
-    move_duration_ = base::Milliseconds(static_cast<int>(
-        std::clamp(170.0f + distance * 0.42f, 190.0f, 620.0f)));
-    phase_started_ = base::TimeTicks::Now();
-    phase_ = Phase::kMoving;
-    overlay_->SetPointer(position_, false);
-    timer_.Start(
-        FROM_HERE, base::Milliseconds(16),
-        base::BindRepeating(&PointerSession::Tick, base::Unretained(this)));
-  }
-
-  void WebContentsDestroyed() override {
-    content::WebContents* key = observed_contents_;
-    Finish(false);
-    base::SequencedTaskRunner::GetCurrentDefault()->PostTask(
-        FROM_HERE,
-        base::BindOnce([](content::WebContents* key) { Sessions().erase(key); },
-                       key));
-  }
-
-  void OnViewIsDeleting(views::View* observed) override {
-    if (observed == overlay_) {
-      overlay_ = nullptr;
-      Finish(false);
-    }
-  }
-
- private:
-  enum class Phase { kIdle, kMoving, kPressed, kBetweenClicks };
-
-  bool AttachOverlay() {
-    BrowserView* browser_view = CurrentBrowserView();
-    if (!browser_view || !browser_view->contents_web_view()) {
-      return false;
-    }
-    if (overlay_ && overlay_->parent() != browser_view) {
-      DetachOverlay();
-    }
-    if (!overlay_) {
-      std::unique_ptr<views::View> overlay = std::make_unique<PointerOverlay>();
-      overlay_ = static_cast<PointerOverlay*>(
-          browser_view->AddChildView(std::move(overlay)));
-      overlay_->AddObserver(this);
-    }
-    UpdateOverlayBounds(browser_view);
-    overlay_->SetVisible(true);
-    return true;
-  }
-
-  void UpdateOverlayBounds(BrowserView* browser_view) {
-    views::View* web_view = browser_view->contents_web_view();
-    overlay_->SetBoundsRect(views::View::ConvertRectToTarget(
-        web_view, browser_view, web_view->GetLocalBounds()));
-  }
-
-  content::RenderWidgetHost* Widget() const {
-    content::RenderFrameHost* frame = web_contents()->GetPrimaryMainFrame();
-    return frame ? frame->GetRenderWidgetHost() : nullptr;
-  }
-
-  BrowserView* CurrentBrowserView() const {
-    return BrowserView::GetBrowserViewForBrowser(
-        chrome::FindBrowserWithTab(web_contents()));
-  }
-
-  void Dispatch(blink::WebInputEvent::Type type, int clicks) {
-    content::RenderWidgetHost* widget = Widget();
-    if (!widget || !widget->GetView()) {
-      return Finish(false);
-    }
-    const gfx::Rect bounds = web_contents()->GetContainerBounds();
-    const auto button = right_button_ ? blink::WebMouseEvent::Button::kRight
-                                      : blink::WebMouseEvent::Button::kLeft;
-    int modifiers = blink::WebInputEvent::kFromDebugger;
-    if (type == blink::WebInputEvent::Type::kMouseDown) {
-      modifiers |= right_button_ ? blink::WebInputEvent::kRightButtonDown
-                                 : blink::WebInputEvent::kLeftButtonDown;
-    }
-    widget->ForwardMouseEvent(
-        MouseEvent(type, button, modifiers, clicks, position_, bounds));
-  }
-
-  void Tick() {
-    if (!overlay_ || !web_contents()) {
-      return Finish(false);
-    }
-    BrowserView* browser_view = CurrentBrowserView();
-    if (!browser_view || overlay_->parent() != browser_view) {
-      return Finish(false);
-    }
-    UpdateOverlayBounds(browser_view);
-    const base::TimeDelta elapsed = base::TimeTicks::Now() - phase_started_;
-    if (phase_ == Phase::kMoving) {
-      const float linear =
-          std::clamp(static_cast<float>(elapsed / move_duration_), 0.0f, 1.0f);
-      const float eased = linear * linear * (3.0f - 2.0f * linear);
-      position_.SetPoint(start_.x() + (target_.x() - start_.x()) * eased,
-                         start_.y() + (target_.y() - start_.y()) * eased);
-      overlay_->SetPointer(position_, false);
-      Dispatch(blink::WebInputEvent::Type::kMouseMove, 0);
-      if (linear >= 1.0f) {
-        content::RenderWidgetHost* widget = Widget();
-        if (widget) {
-          widget->Focus();
-        }
-        BeginPress();
-      }
-      return;
-    }
-    if (phase_ == Phase::kPressed && elapsed >= base::Milliseconds(58)) {
-      Dispatch(blink::WebInputEvent::Type::kMouseUp, completed_clicks_ + 1);
-      overlay_->SetPointer(position_, false);
-      overlay_->Pulse();
-      ++completed_clicks_;
-      if (completed_clicks_ >= click_count_) {
-        return Finish(true);
-      }
-      phase_ = Phase::kBetweenClicks;
-      phase_started_ = base::TimeTicks::Now();
-      return;
-    }
-    if (phase_ == Phase::kBetweenClicks && elapsed >= base::Milliseconds(92)) {
-      BeginPress();
-    }
-  }
-
-  void BeginPress() {
-    phase_ = Phase::kPressed;
-    phase_started_ = base::TimeTicks::Now();
-    overlay_->SetPointer(position_, true);
-    Dispatch(blink::WebInputEvent::Type::kMouseDown, completed_clicks_ + 1);
-  }
-
-  void Finish(bool success) {
-    timer_.Stop();
-    phase_ = Phase::kIdle;
-    has_position_ = has_position_ || success;
-    if (overlay_) {
-      overlay_->SetPointer(position_, false);
-      hide_timer_.Start(
-          FROM_HERE, base::Milliseconds(520),
-          base::BindOnce(&PointerSession::HideOverlay, base::Unretained(this)));
-    }
-    if (callback_) {
-      std::move(callback_).Run(success);
-    }
-  }
-
-  void HideOverlay() {
-    if (overlay_ && phase_ == Phase::kIdle) {
-      overlay_->ClearPulse();
-      overlay_->SetVisible(false);
-    }
-  }
-
-  void DetachOverlay() {
-    hide_timer_.Stop();
-    if (!overlay_) {
-      return;
-    }
-    overlay_->RemoveObserver(this);
-    if (overlay_->parent()) {
-      overlay_->parent()->RemoveChildViewT(overlay_);
-    }
-    overlay_ = nullptr;
-  }
-
-  raw_ptr<content::WebContents> observed_contents_ = nullptr;
-  raw_ptr<PointerOverlay> overlay_ = nullptr;
-  gfx::PointF start_;
-  gfx::PointF position_;
-  gfx::PointF target_;
-  base::TimeTicks phase_started_;
-  base::TimeDelta move_duration_;
-  base::RepeatingTimer timer_;
-  base::OneShotTimer hide_timer_;
-  base::OnceCallback<void(bool)> callback_;
-  Phase phase_ = Phase::kIdle;
-  int click_count_ = 1;
-  int completed_clicks_ = 0;
-  bool right_button_ = false;
-  bool has_position_ = false;
-};
-
-SessionMap& Sessions() {
-  static base::NoDestructor<SessionMap> sessions;
-  return *sessions;
-}
-
-}  // namespace
