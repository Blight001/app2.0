-void DispatchAiFreeAnimatedClick(content::WebContents* web_contents,
-                                 const gfx::PointF& target,
-                                 bool right_button,
-                                 int click_count,
-                                 base::OnceCallback<void(bool)> callback) {
-  auto [it, inserted] = Sessions().try_emplace(web_contents);
-  if (inserted) {
-    it->second = std::make_unique<PointerSession>(web_contents);
-  }
-  it->second->Start(target, right_button, click_count, std::move(callback));
-}
