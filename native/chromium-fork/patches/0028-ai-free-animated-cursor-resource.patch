 namespace {
 
+constexpr char kAutomationCursorSwitch[] = "hs-automation-cursor";
+
+class AnimatedCursorFrames {
+ public:
+  AnimatedCursorFrames() {
+    const base::FilePath path =
+        base::CommandLine::ForCurrentProcess()->GetSwitchValuePath(
+            kAutomationCursorSwitch);
+    if (!path.empty()) {
+      cursor_ = LoadCursorFromFileW(path.value().c_str());
+    }
+    HMODULE user32 = GetModuleHandleW(L"user32.dll");
+    if (user32) {
+      frame_info_ = reinterpret_cast<GetCursorFrameInfo>(
+          GetProcAddress(user32, "GetCursorFrameInfo"));
+    }
+  }
+
+  ~AnimatedCursorFrames() {
+    if (cursor_) {
+      DestroyCursor(cursor_);
+    }
+  }
+
+  bool available() const { return cursor_ != nullptr; }
+
+  bool Paint(gfx::Canvas* canvas, const gfx::PointF& point) {
+    if (!cursor_) {
+      return false;
+    }
+    const base::TimeTicks now = base::TimeTicks::Now();
+    const bool advance =
+        !next_frame_.is_null() && now >= next_frame_;
+    if (advance && frame_count_ > 1) {
+      frame_index_ = (frame_index_ + 1) % frame_count_;
+    }
+    DWORD rate = 6;
+    DWORD steps = frame_count_;
+    HCURSOR frame = frame_info_
+                        ? frame_info_(cursor_, L"", frame_index_, &rate, &steps)
+                        : cursor_;
+    if (!frame) {
+      frame_index_ = 0;
+      frame = cursor_;
+      rate = 6;
+      steps = 1;
+    }
+    frame_count_ = std::max(steps, DWORD{1});
+    const SkBitmap bitmap = IconUtil::CreateSkBitmapFromHICON(frame);
+    if (bitmap.isNull()) {
+      return false;
+    }
+    const gfx::Point hotspot = IconUtil::GetHotSpotFromHICON(frame);
+    canvas->DrawImageInt(
+        gfx::ImageSkia::CreateFrom1xBitmap(bitmap),
+        std::lround(point.x()) - hotspot.x(),
+        std::lround(point.y()) - hotspot.y());
+    if (next_frame_.is_null() || advance) {
+      const DWORD bounded_rate = std::clamp(rate, DWORD{1}, DWORD{60});
+      next_frame_ =
+          now + base::Milliseconds(static_cast<int>(bounded_rate * 1000 / 60));
+    }
+    return true;
+  }
+
+ private:
+  using GetCursorFrameInfo =
+      HCURSOR(WINAPI*)(HCURSOR, LPCWSTR, DWORD, LPDWORD, LPDWORD);
+
+  HCURSOR cursor_ = nullptr;
+  GetCursorFrameInfo frame_info_ = nullptr;
+  DWORD frame_index_ = 0;
+  DWORD frame_count_ = 1;
+  base::TimeTicks next_frame_;
+};
