diff --git a/chrome/browser/permissions/ai_free_permission_policy_unittest.cc b/chrome/browser/permissions/ai_free_permission_policy_unittest.cc
new file mode 100644
index 00000000..c240cbd6
--- /dev/null
+++ b/chrome/browser/permissions/ai_free_permission_policy_unittest.cc
@@ -0,0 +1,72 @@
+// Copyright 2026 AI-FREE Authors. All rights reserved.
+
+#include "chrome/browser/permissions/ai_free_permission_policy.h"
+
+#include <string_view>
+
+#include "base/test/scoped_command_line.h"
+#include "chrome/common/chrome_switches.h"
+#include "testing/gtest/include/gtest/gtest.h"
+#include "url/gurl.h"
+#include "url/origin.h"
+
+namespace ai_free {
+namespace {
+
+class AiFreePermissionPolicyTest : public testing::Test {
+ protected:
+  void Enable(std::string_view origins) {
+    command_line_.GetProcessCommandLine()->AppendSwitchASCII(
+        switches::kHsEmbedMode, "child-window");
+    command_line_.GetProcessCommandLine()->AppendSwitch(
+        switches::kAutoGrantPermissions);
+    command_line_.GetProcessCommandLine()->AppendSwitchASCII(
+        switches::kAutoGrantPermissionsOrigins, origins);
+  }
+
+  base::test::ScopedCommandLine command_line_;
+};
+
+TEST_F(AiFreePermissionPolicyTest, RequiresEmbeddedMode) {
+  command_line_.GetProcessCommandLine()->AppendSwitch(
+      switches::kAutoGrantPermissions);
+  command_line_.GetProcessCommandLine()->AppendSwitchASCII(
+      switches::kAutoGrantPermissionsOrigins, "https://allowed.test");
+  EXPECT_FALSE(ArePermissionOriginsAllowlisted(
+      GURL("https://allowed.test"),
+      url::Origin::Create(GURL("https://allowed.test"))));
+}
+
+TEST_F(AiFreePermissionPolicyTest, RequiresBothOrigins) {
+  Enable("https://allowed.test,https://top.test:443");
+  EXPECT_TRUE(ArePermissionOriginsAllowlisted(
+      GURL("https://allowed.test/path"),
+      url::Origin::Create(GURL("https://top.test"))));
+  EXPECT_FALSE(ArePermissionOriginsAllowlisted(
+      GURL("https://allowed.test"),
+      url::Origin::Create(GURL("https://other.test"))));
+}
+
+TEST_F(AiFreePermissionPolicyTest, RejectsBroadEntries) {
+  Enable("https://*.test,https://path.test/not-root,http://remote.test,http://localhost:8080");
+  EXPECT_FALSE(ArePermissionOriginsAllowlisted(
+      GURL("https://path.test"),
+      url::Origin::Create(GURL("https://path.test"))));
+  EXPECT_TRUE(ArePermissionOriginsAllowlisted(
+      GURL("http://localhost:8080"),
+      url::Origin::Create(GURL("http://localhost:8080"))));
+}
+
+TEST_F(AiFreePermissionPolicyTest, GrantsOnlyExplicitTypes) {
+  EXPECT_TRUE(IsAutoGrantPermissionType(
+      permissions::RequestType::kGeolocation));
+  EXPECT_TRUE(IsAutoGrantPermissionType(
+      permissions::RequestType::kCameraStream));
+  EXPECT_FALSE(IsAutoGrantPermissionType(
+      permissions::RequestType::kFileSystemAccess));
+  EXPECT_FALSE(IsAutoGrantPermissionType(
+      permissions::RequestType::kMidiSysex));
+}
+
+}  // namespace
+}  // namespace ai_free
