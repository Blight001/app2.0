new file mode 100644
index 00000000..0caaea68
--- /dev/null
+++ b/chrome/browser/permissions/ai_free_permission_policy.cc
@@ -0,0 +1,91 @@
+// Copyright 2026 AI-FREE Authors. All rights reserved.
+
+#include "chrome/browser/permissions/ai_free_permission_policy.h"
+
+#include <string>
+#include <string_view>
+
+#include "base/command_line.h"
+#include "base/containers/flat_set.h"
+#include "base/strings/string_split.h"
+#include "chrome/common/chrome_switches.h"
+#include "net/base/url_util.h"
+#include "url/gurl.h"
+#include "url/origin.h"
+
+namespace ai_free {
+namespace {
+
+constexpr char kEmbeddedModeValue[] = "child-window";
+
+bool IsValidAllowlistUrl(const GURL& url) {
+  if (!url.is_valid() || url.has_username() || url.has_password() ||
+      url.has_query() || url.has_ref() || url.path() != "/") {
+    return false;
+  }
+  return url.SchemeIs(url::kHttpsScheme) ||
+         (url.SchemeIs(url::kHttpScheme) && net::IsLocalhost(url));
+}
+
+base::flat_set<url::Origin> ParseOriginAllowlist() {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  base::flat_set<url::Origin> origins;
+  const std::string value = command_line->GetSwitchValueASCII(
+      switches::kAutoGrantPermissionsOrigins);
+  for (std::string_view entry : base::SplitStringPiece(
+           value, ",", base::TRIM_WHITESPACE, base::SPLIT_WANT_NONEMPTY)) {
+    const GURL url(entry);
+    if (!IsValidAllowlistUrl(url)) {
+      continue;
+    }
+    url::Origin origin = url::Origin::Create(url);
+    if (!origin.opaque()) {
+      origins.insert(std::move(origin));
+    }
+  }
+  return origins;
+}
+
+}  // namespace
+
+bool IsEmbeddedAutomationMode() {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  return command_line->GetSwitchValueASCII(switches::kHsEmbedMode) ==
+         kEmbeddedModeValue;
+}
+
+bool ArePermissionOriginsAllowlisted(const GURL& requesting_origin,
+                                     const url::Origin& top_level_origin) {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!IsEmbeddedAutomationMode() ||
+      !command_line->HasSwitch(switches::kAutoGrantPermissions)) {
+    return false;
+  }
+
+  const url::Origin request_origin = url::Origin::Create(requesting_origin);
+  if (request_origin.opaque() || top_level_origin.opaque()) {
+    return false;
+  }
+  const base::flat_set<url::Origin> origins = ParseOriginAllowlist();
+  return !origins.empty() && origins.contains(request_origin) &&
+         origins.contains(top_level_origin);
+}
+
+bool IsAutoGrantPermissionType(permissions::RequestType request_type) {
+  switch (request_type) {
+    case permissions::RequestType::kCameraStream:
+    case permissions::RequestType::kClipboard:
+    case permissions::RequestType::kGeolocation:
+    case permissions::RequestType::kMicStream:
+    case permissions::RequestType::kNotifications:
+    case permissions::RequestType::kSensors:
+      return true;
+    default:
+      return false;
+  }
+}
+
+}  // namespace ai_free
