+std::optional<permissions::PermissionAction>
+ChromePermissionsClient::GetAutoApprovalStatusForRequest(
+    content::BrowserContext* browser_context,
+    content::RenderFrameHost* source_frame,
+    const permissions::PermissionRequest& request) {
+  Profile* profile = Profile::FromBrowserContext(browser_context);
+  if (profile && !profile->IsOffTheRecord() && source_frame &&
+      ai_free::IsAutoGrantPermissionType(request.request_type())) {
+    const url::Origin top_level_origin =
+        source_frame->GetOutermostMainFrame()->GetLastCommittedOrigin();
+    if (ai_free::ArePermissionOriginsAllowlisted(request.requesting_origin(),
+                                                 top_level_origin)) {
+      VLOG(1) << "AI-FREE auto-granted permission type="
+              << static_cast<int>(request.request_type())
+              << " origin=" << request.requesting_origin();
+      return permissions::PermissionAction::GRANTED_ONCE;
+    }
+  }
+  return GetAutoApprovalStatus(browser_context, request.requesting_origin());
+}
