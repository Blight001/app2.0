+void RunWaitAttempt(content::GlobalRenderFrameHostId frame_id,
+                    std::string script,
+                    base::TimeTicks deadline,
+                    AiFreeAutomationSuccess success,
+                    AiFreeAutomationFailure failure);
+
+void OnWaitResult(content::GlobalRenderFrameHostId frame_id,
+                  std::string script,
+                  base::TimeTicks deadline,
+                  AiFreeAutomationSuccess success,
+                  AiFreeAutomationFailure failure,
+                  base::Value value) {
+  const base::DictValue* result = value.GetIfDict();
+  if (!result) {
+    return Fail(std::move(failure), "ACTION_RESULT_INVALID",
+                "等待动作未返回对象");
+  }
+  if (result->FindBool("success").value_or(false)) {
+    return std::move(success).Run(result->Clone());
+  }
+  const std::string* error_code = result->FindString("errorCode");
+  if (!error_code || *error_code != "WAIT_PENDING") {
+    return std::move(success).Run(result->Clone());
+  }
+  if (base::TimeTicks::Now() >= deadline) {
+    base::DictValue response = result->Clone();
+    response.Set("error", "等待元素超时");
+    response.Set("errorCode", "WAIT_TIMEOUT");
+    return std::move(success).Run(std::move(response));
+  }
+  base::SequencedTaskRunner::GetCurrentDefault()->PostDelayedTask(
+      FROM_HERE,
+      base::BindOnce(&RunWaitAttempt, frame_id, std::move(script), deadline,
+                     std::move(success), std::move(failure)),
+      base::Milliseconds(100));
+}
+
+void RunWaitAttempt(content::GlobalRenderFrameHostId frame_id,
+                    std::string script,
+                    base::TimeTicks deadline,
+                    AiFreeAutomationSuccess success,
+                    AiFreeAutomationFailure failure) {
+  content::RenderFrameHost* frame = content::RenderFrameHost::FromID(frame_id);
+  content::WebContents* contents =
+      frame ? content::WebContents::FromRenderFrameHost(frame) : nullptr;
+  if (!contents) {
+    return Fail(std::move(failure), "INPUT_TARGET_UNAVAILABLE",
+                "等待页面目标不可用");
+  }
+  std::string execution_script = script;
+  auto callback =
+      base::BindOnce(&OnWaitResult, frame_id, std::move(script), deadline,
+                     std::move(success), std::move(failure));
+  ExecuteIsolated(contents, std::move(execution_script), std::move(callback));
+}
