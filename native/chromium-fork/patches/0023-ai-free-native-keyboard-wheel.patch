+input::NativeWebKeyboardEvent KeyboardEvent(blink::WebInputEvent::Type type,
+                                             int windows_key_code) {
+  input::NativeWebKeyboardEvent event(type, blink::WebInputEvent::kNoModifiers,
+                                      ui::EventTimeForNow());
+  event.windows_key_code = windows_key_code;
+  return event;
+}
+
+void DispatchText(content::RenderWidgetHost* widget, std::string_view text) {
+  content::RenderWidgetHostImpl::From(widget)->ImeCommitText(
+      base::UTF8ToUTF16(text), {}, gfx::Range::InvalidRange(), 0);
+}
+
+int KeyCode(std::string_view key) {
+  if (key == "Tab") return 0x09;
+  if (key == "Escape") return 0x1B;
+  if (key == "Backspace") return 0x08;
+  if (key == "ArrowLeft") return 0x25;
+  if (key == "ArrowUp") return 0x26;
+  if (key == "ArrowRight") return 0x27;
+  if (key == "ArrowDown") return 0x28;
+  return 0x0D;
+}
+
+bool DispatchKeyboard(content::WebContents* contents,
+                      std::string_view action,
+                      std::string_view value) {
+  content::RenderWidgetHost* widget =
+      contents->GetPrimaryMainFrame()->GetRenderWidgetHost();
+  if (!widget) return false;
+  widget->Focus();
+  if (action == "type") {
+    DispatchText(widget, value);
+    return true;
+  }
+  const int key_code = KeyCode(value);
+  input::NativeWebKeyboardEvent key_down =
+      KeyboardEvent(blink::WebInputEvent::Type::kRawKeyDown, key_code);
+  key_down.dom_key =
+      static_cast<int>(ui::KeycodeConverter::KeyStringToDomKey(value));
+  key_down.dom_code =
+      static_cast<int>(ui::KeycodeConverter::CodeStringToDomCode(value));
+  input::NativeWebKeyboardEvent key_up = key_down;
+  key_up.SetType(blink::WebInputEvent::Type::kKeyUp);
+  widget->ForwardKeyboardEvent(key_down);
+  widget->ForwardKeyboardEvent(key_up);
+  return true;
+}
+
+bool DispatchScroll(content::WebContents* contents,
+                    const base::DictValue& command) {
+  content::RenderWidgetHost* widget =
+      contents->GetPrimaryMainFrame()->GetRenderWidgetHost();
+  if (!widget || !widget->GetView()) return false;
+  const double amount = command.FindDouble("amount").value_or(600.0);
+  const bool up = command.FindString("direction") &&
+                  *command.FindString("direction") == "up";
+  blink::WebMouseWheelEvent event(blink::WebInputEvent::Type::kMouseWheel,
+                                  blink::WebInputEvent::kNoModifiers,
+                                  ui::EventTimeForNow());
+  event.delta_y = static_cast<float>(up ? amount : -amount);
+  event.wheel_ticks_y = up ? 1.0f : -1.0f;
+  event.delta_units = ui::ScrollGranularity::kScrollByPixel;
+  event.event_action = blink::WebMouseWheelEvent::EventAction::kScrollVertical;
+  widget->ForwardWheelEvent(event);
+  return true;
+}
