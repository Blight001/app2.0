+void Fail(AiFreeAutomationFailure failure,
+          std::string code,
+          std::string message) {
+  std::move(failure).Run({std::move(code), std::move(message)});
+}
+
+std::string CommandJson(const base::DictValue& command) {
+  return base::WriteJson(command).value_or("{}");
+}
+
+void ExecuteIsolated(content::WebContents* web_contents,
+                     std::string script,
+                     base::OnceCallback<void(base::Value)> callback) {
+  web_contents->GetPrimaryMainFrame()->ExecuteJavaScriptInIsolatedWorld(
+      base::UTF8ToUTF16(script), std::move(callback),
+      ISOLATED_WORLD_ID_CHROME_INTERNAL);
+}
