+base::DictValue BuildTabResult(Browser* browser,
+                               const std::string& action) {
+  TabStripModel* model = browser->tab_strip_model();
+  base::ListValue tabs;
+  for (int index = 0; index < model->count(); ++index) {
+    content::WebContents* contents = model->GetWebContentsAt(index);
+    base::DictValue tab;
+    tab.Set("tabId", index);
+    tab.Set("active", index == model->active_index());
+    tab.Set("title", base::UTF16ToUTF8(contents->GetTitle()));
+    tab.Set("url", contents->GetLastCommittedURL().spec());
+    tabs.Append(std::move(tab));
+  }
+  base::DictValue result;
+  result.Set("success", true);
+  result.Set("action", action);
+  result.Set("activeTabId", model->active_index());
+  result.Set("tabs", std::move(tabs));
+  return result;
+}
+
+void HandleManageTabs(scoped_refptr<BridgeConnection> connection,
+                      Browser* browser,
+                      const base::DictValue& command,
+                      const std::string& request_id) {
+  TabStripModel* model = browser->tab_strip_model();
+  const std::string* action_value = command.FindString("action");
+  const std::string action = action_value ? *action_value : "list";
+  int tab_id = command.FindInt("tabId").value_or(model->active_index());
+  if (action == "list") {
+    return connection->SendSuccessAsync(
+        request_id, "manage-tabs", BuildTabResult(browser, action));
+  }
+  if (action == "navigate") {
+    const std::string* url_value = command.FindString("url");
+    const GURL url(url_value ? *url_value : std::string());
+    if (!IsAllowedWebUrl(url)) {
+      return connection->SendErrorAsync(request_id, "manage-tabs",
+                                        "URL_INVALID", "标签页 URL 无效");
+    }
+    NavigateParams params(browser, url, ui::PAGE_TRANSITION_LINK);
+    params.disposition = WindowOpenDisposition::NEW_FOREGROUND_TAB;
+    Navigate(&params);
+  } else {
+    if (tab_id < 0 || tab_id >= model->count()) {
+      return connection->SendErrorAsync(request_id, "manage-tabs",
+                                        "TAB_NOT_FOUND", "标签页不存在");
+    }
+    content::WebContents* contents = model->GetWebContentsAt(tab_id);
+    if (action == "switch") {
+      model->ActivateTabAt(tab_id);
+    } else if (action == "close") {
+      model->CloseWebContentsAt(
+          tab_id, TabCloseTypes::CLOSE_CREATE_HISTORICAL_TAB);
+    } else if (action == "back" && contents->GetController().CanGoBack()) {
+      contents->GetController().GoBack();
+    } else if (action == "forward" &&
+               contents->GetController().CanGoForward()) {
+      contents->GetController().GoForward();
+    } else {
+      return connection->SendErrorAsync(request_id, "manage-tabs",
+                                        "TAB_ACTION_INVALID",
+                                        "标签页操作不可用");
+    }
+  }
+  connection->SendSuccessAsync(
+      request_id, "manage-tabs", BuildTabResult(browser, action));
+}
