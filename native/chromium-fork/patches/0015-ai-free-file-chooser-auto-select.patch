+++ b/chrome/browser/ai_free_file_selection.h
@@ -0,0 +1,42 @@
+// Copyright 2026 AI-FREE Authors. All rights reserved.
+
+#ifndef CHROME_BROWSER_AI_FREE_FILE_SELECTION_H_
+#define CHROME_BROWSER_AI_FREE_FILE_SELECTION_H_
+
+#include <optional>
+#include <vector>
+
+#include "base/files/file_path.h"
+#include "base/time/time.h"
+#include "content/public/browser/web_contents_user_data.h"
+#include "url/origin.h"
+
+class AiFreeFileSelection
+    : public content::WebContentsUserData<AiFreeFileSelection> {
+ public:
+  enum class Mode { kOpen, kOpenMultiple, kUploadFolder };
+  struct Request {
+    Request();
+    Request(Request&&);
+    Request& operator=(Request&&);
+    ~Request();
+    std::vector<base::FilePath> paths;
+    url::Origin origin;
+    Mode mode = Mode::kOpen;
+    base::TimeTicks expires_at;
+  };
+
+  AiFreeFileSelection(const AiFreeFileSelection&) = delete;
+  AiFreeFileSelection& operator=(const AiFreeFileSelection&) = delete;
+  ~AiFreeFileSelection() override;
+  void Queue(Request request);
+  std::optional<Request> Consume(const url::Origin& current_origin, Mode mode);
+
+ private:
+  explicit AiFreeFileSelection(content::WebContents* web_contents);
+  friend class content::WebContentsUserData<AiFreeFileSelection>;
+  WEB_CONTENTS_USER_DATA_KEY_DECL();
+  std::optional<Request> request_;
+};
+
+#endif  // CHROME_BROWSER_AI_FREE_FILE_SELECTION_H_
