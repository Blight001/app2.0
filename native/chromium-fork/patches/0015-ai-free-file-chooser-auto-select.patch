@@ -0,0 +1,35 @@
+// Copyright 2026 AI-FREE Authors. All rights reserved.
+
+#include "chrome/browser/ai_free_file_selection.h"
+
+AiFreeFileSelection::Request::Request() = default;
+AiFreeFileSelection::Request::Request(Request&&) = default;
+AiFreeFileSelection::Request& AiFreeFileSelection::Request::operator=(Request&&) = default;
+AiFreeFileSelection::Request::~Request() = default;
+AiFreeFileSelection::AiFreeFileSelection(content::WebContents* web_contents)
+    : content::WebContentsUserData<AiFreeFileSelection>(*web_contents) {}
+AiFreeFileSelection::~AiFreeFileSelection() = default;
+
+void AiFreeFileSelection::Queue(Request request) {
+  request_ = std::move(request);
+}
+
+std::optional<AiFreeFileSelection::Request> AiFreeFileSelection::Consume(
+    const url::Origin& current_origin,
+    Mode mode) {
+  if (!request_) return std::nullopt;
+  const bool mode_matches = request_->mode == mode ||
+                            (request_->mode == Mode::kOpen &&
+                             mode == Mode::kOpenMultiple &&
+                             request_->paths.size() == 1);
+  if (base::TimeTicks::Now() >= request_->expires_at ||
+      request_->origin != current_origin || !mode_matches) {
+    request_.reset();
+    return std::nullopt;
+  }
+  std::optional<Request> result = std::move(request_);
+  request_.reset();
+  return result;
+}
+
+WEB_CONTENTS_USER_DATA_KEY_IMPL(AiFreeFileSelection);
