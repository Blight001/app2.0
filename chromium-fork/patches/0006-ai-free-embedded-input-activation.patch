 bool HWNDMessageHandler::IsActive() const {
+  // AI-FREE reparents the normal Chromium Browser HWND as a WS_CHILD owned by
+  // its native host. Win32 never treats a child HWND as the active top-level
+  // window, so use native focus as the activation signal only in the explicit
+  // AI-FREE child-window mode. Ordinary Chromium windows keep the standard
+  // GetActiveWindow() behavior below.
+  if (::GetParent(hwnd()) &&
+      base::CommandLine::ForCurrentProcess()->GetSwitchValueASCII(
+          "hs-embed-mode") == "child-window") {
+    HWND focused = ::GetFocus();
+    return focused == hwnd() || (focused && ::IsChild(hwnd(), focused));
+  }
   return ::GetActiveWindow() == hwnd();
 }
 
