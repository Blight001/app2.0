{
  "name": "ai-free",
  "version": "2.6.1",
  "private": true,
  "description": "Assistant to help creators use AI more conveniently",
  "main": "src/app/main/main.js",
  "workspaces": [],
  "scripts": {
    "start": "node scripts/run-chromium-fork.js .",
    "start:electron": "node scripts/run-electron.js .",
    "start:dev": "node scripts/run-electron.js .",
    "start:chromium": "node scripts/run-chromium-fork.js .",
    "start:prototype": "node scripts/run-chromium-runtime.js .",
    "smoke:chromium": "node scripts/run-electron.js scripts/smoke-chromium-embed.js",
    "accept:chromium-phase2": "node scripts/run-electron.js scripts/accept-chromium-phase2.js",
    "accept:chromium-input": "node scripts/run-electron.js scripts/accept-chromium-input.js",
    "accept:chromium-phase3": "node scripts/run-electron.js scripts/accept-chromium-phase3.js",
    "check:http-routing": "node scripts/check-http-tenant-routing.js",
    "check:announcements": "node scripts/check-announcement-polling.js",
    "check:extension-compat": "node scripts/check-extension-compat.js",
    "check:extension-refresh": "node scripts/check-extension-refresh.js",
    "check:browser-runtime": "node scripts/check-browser-runtime.js",
    "check:browser-settings": "node scripts/check-browser-settings.js",
    "check:browser-settings-ui": "node scripts/run-electron.js scripts/check-browser-settings-ui.js",
    "check:chromium-handshake": "node scripts/check-chromium-handshake.js",
    "check:chromium-embedded-policy": "node scripts/check-chromium-embedded-policy.js",
    "build:native-host": "node scripts/build-native-host.js",
    "build": "electron-builder",
    "build:win": "node scripts/build-windows.js",
    "build:portable": "electron-builder --win portable"
  },
  "keywords": [],
  "author": "HeySure",
  "license": "ISC",
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^40.0.0",
    "electron-builder": "^26.0.12",
    "javascript-obfuscator": "^5.4.6"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "axios": "^1.13.2",
    "express": "^4.18.2",
    "extract-zip": "^2.0.1",
    "fs-extra": "^11.1.1",
    "imap-simple": "^5.1.0",
    "js-yaml": "^4.1.1",
    "multer": "^1.4.5-lts.1",
    "node-machine-id": "^1.1.12",
    "nodemailer": "^6.9.7",
    "playwright": "^1.40.0",
    "sharp": "^0.34.5",
    "tar": "^7.4.3",
    "vm2": "^3.10.5",
    "yaml": "^2.6.0"
  },
  "build": {
    "afterPack": "scripts/obfuscate-packaged-extensions.js",
    "appId": "com.ai-free.app",
    "productName": "AI-FREE",
    "directories": {
      "output": "appbuild"
    },
    "files": [
      "src/**/*",
      "native/browser-host/build/Release/browser_host.node",
      "!src/DEV_MAP.md",
      "!src/assets/extensions/remove_watermark/**/*.map",
      "!src/assets/extensions/remove_watermark/**/*.LICENSE.txt",
      "!src/assets/extensions/remove_watermark/remove_watermark.crx",
      "assets/**/*",
      "!assets/extensions/remove_watermark/**/*.map",
      "!assets/extensions/remove_watermark/**/*.LICENSE.txt",
      "!assets/extensions/remove_watermark/remove_watermark.crx",
      "docs/config/platforms-config.json",
      "package.json",
      "package-lock.json",
      "!node_modules/onnxruntime-node/**"
    ],
    "extraResources": [
      {
        "from": "native/browser-host/build/Release/browser_host.node",
        "to": "native/browser-host/browser_host.node"
      },
      {
        "from": "resources/chromium",
        "to": "chromium"
      },
      {
        "from": "resources/clash-mini/core",
        "to": "clash-mini/core"
      },
      {
        "from": "src/assets/seedance2.0.ico",
        "to": "resource/seedance2.0.ico"
      }
    ],
    "win": {
      "signExts": [
        "!verge-mihomo.exe"
      ],
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/seedance2.0.ico",
      "signtoolOptions": {
        "signingHashAlgorithms": [
          "sha256"
        ],
        "timeStampServer": "http://timestamp.digicert.com"
      }
    },
    "asar": {
      "smartUnpack": true
    },
    "asarUnpack": [
      "src/assets/extensions/**"
    ],
    "compression": "maximum",
    "electronLanguages": [
      "zh-CN"
    ],
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "src/assets/seedance2.0.ico",
      "uninstallerIcon": "src/assets/seedance2.0.ico",
      "installerHeaderIcon": "src/assets/seedance2.0.ico"
    },
    "icon": "src/assets/seedance2.0.ico"
  },
  "icon": "src/assets/seedance2.0.ico"
}
