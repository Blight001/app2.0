{
  "name": "ai-free",
  "version": "2.6.11",
  "private": true,
  "description": "Assistant to help creators use AI more conveniently",
  "main": "src/app/main/main.js",
  "workspaces": [],
  "scripts": {
    "prepare:source": "node scripts/build-source.js",
    "start": "npm run prepare:source && node scripts/run-chromium-fork.js .generated/app",
    "start:electron": "npm run prepare:source && node scripts/run-electron.js .generated/app",
    "start:dev": "npm run prepare:source && node scripts/run-electron.js .generated/app",
    "start:chromium": "npm run prepare:source && node scripts/run-chromium-fork.js .generated/app",
    "start:prototype": "node scripts/run-chromium-runtime.js .",
    "smoke:chromium": "node scripts/run-electron.js scripts/smoke-chromium-embed.js",
    "accept:chromium-phase2": "node scripts/run-electron.js scripts/accept-chromium-phase2.js",
    "accept:chromium-input": "node scripts/run-electron.js scripts/accept-chromium-input.js",
    "accept:chromium-phase3": "node scripts/run-electron.js scripts/accept-chromium-phase3.js",
    "check:account-session": "node --test test/unit/account/account-service.test.js test/integration/account-device-login.test.js",
    "check:session-storage": "node scripts/run-electron.js scripts/check-session-storage.js",
    "check:announcements": "node scripts/check-announcement-polling.js",
    "check:extension-compat": "node scripts/check-extension-compat.js",
    "check:extension-refresh": "node scripts/check-extension-refresh.js",
    "check:browser-observe": "node scripts/run-electron.js scripts/check-browser-observe.js",
    "check:browser-runtime": "node scripts/check-browser-runtime.js",
    "check:browser-settings": "node --test test/unit/browser-profile-geo.test.js test/integration/tab-runtime-environment.test.js test/integration/browser-window-lifecycle.test.js",
    "check:browser-settings-ui": "node scripts/run-electron.js scripts/check-browser-settings-ui.js",
    "check:chromium-handshake": "node scripts/check-chromium-handshake.js",
    "check:chromium-embedded-policy": "node scripts/check-chromium-embedded-policy.js",
    "check:packaged-runtime": "node scripts/verify-packaged-runtime.js appbuild/win-unpacked",
    "build:native-host": "node scripts/build-native-host.js",
    "build": "npm run prepare:source && npm run build:native-host && electron-builder",
    "build:win": "node scripts/build-windows.js",
    "build:portable": "npm run prepare:source && npm run build:native-host && electron-builder --win portable",
    "pretest": "npm run prepare:source",
    "test": "node --test \"test/**/*.test.js\"",
    "test:unit": "node --test \"test/unit/**/*.test.js\"",
    "test:contract": "node --test \"test/contract/**/*.test.js\"",
    "test:integration": "node --test \"test/integration/**/*.test.js\"",
    "test:packaging": "node --test \"test/packaging/**/*.test.js\"",
    "test:acceptance": "npm run check:extension-compat && npm run check:extension-refresh && npm run check:chromium-handshake && npm run check:browser-runtime && npm run check:browser-observe && npm run check:browser-settings-ui && npm run check:session-storage",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-exclude=test/** --test-coverage-exclude=scripts/** --test-coverage-exclude=native/** --test-coverage-exclude=.generated/** --test-coverage-lines=75 --test-coverage-branches=65 --test-coverage-functions=70 \"test/**/*.test.js\"",
    "format:check": "git diff --check -- .",
    "check:architecture": "node --test test/contract/ipc/channels-registry.test.js test/packaging/assets/source-build.test.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "guardrails": "node scripts/check-guardrails.js",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run check:architecture && npm test && npm run test:coverage && npm run prepare:source"
  },
  "keywords": [],
  "author": "HeySure",
  "license": "ISC",
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^40.0.0",
    "electron-builder": "^26.0.12",
    "eslint": "^10.7.0",
    "javascript-obfuscator": "^5.4.6",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "axios": "^1.13.2",
    "express": "^4.18.2",
    "extract-zip": "^2.0.1",
    "fs-extra": "^11.1.1",
    "https-proxy-agent": "^7.0.6",
    "imap-simple": "^5.1.0",
    "js-yaml": "^4.1.1",
    "multer": "^1.4.5-lts.1",
    "node-machine-id": "^1.1.12",
    "nodemailer": "^6.9.7",
    "playwright": "^1.40.0",
    "sharp": "^0.34.5",
    "socket.io-client": "^4.8.3",
    "tar": "^7.4.3",
    "vm2": "^3.10.5",
    "yaml": "^2.6.0"
  },
  "build": {
    "afterPack": "scripts/obfuscate-packaged-extensions.js",
    "appId": "com.ai-free.app",
    "productName": "AI-FREE",
    "directories": {
      "output": "appbuild"
    },
    "files": [
      {
        "from": ".generated/app/src",
        "to": "src",
        "filter": [
          "**/*",
          "!assets/logo.ico",
          "!assets/extensions/remove_watermark/**/*.map",
          "!assets/extensions/remove_watermark/**/*.LICENSE.txt",
          "!assets/extensions/remove_watermark/remove_watermark.crx"
        ]
      },
      "!src/assets/logo.ico",
      "!src/assets/extensions/remove_watermark/**/*.map",
      "!src/assets/extensions/remove_watermark/**/*.LICENSE.txt",
      "!src/assets/extensions/remove_watermark/remove_watermark.crx",
      "assets/**/*",
      "!assets/extensions/remove_watermark/**/*.map",
      "!assets/extensions/remove_watermark/**/*.LICENSE.txt",
      "!assets/extensions/remove_watermark/remove_watermark.crx",
      "platforms-config.json",
      "package.json",
      "package-lock.json",
      "!node_modules/onnxruntime-node/**"
    ],
    "extraResources": [
      {
        "from": "native/browser-host/build/Release/browser_host.node",
        "to": "native/browser-host/browser_host.node"
      },
      {
        "from": "resources/chromium",
        "to": "chromium"
      },
      {
        "from": "resources/clash-mini/core",
        "to": "clash-mini/core"
      },
      {
        "from": "src/assets/logo.ico",
        "to": "resource/logo.ico"
      }
    ],
    "win": {
      "signExts": [
        "!verge-mihomo.exe"
      ],
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/logo.ico",
      "signtoolOptions": {
        "signingHashAlgorithms": [
          "sha256"
        ],
        "timeStampServer": "http://timestamp.digicert.com"
      }
    },
    "asar": {
      "smartUnpack": true
    },
    "asarUnpack": [
      "**/assets/extensions/**/*",
      "**/app/main/runtime/crash-watchdog/**/*"
    ],
    "compression": "maximum",
    "electronLanguages": [
      "zh-CN"
    ],
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "scripts/installer.nsh",
      "installerIcon": "src/assets/logo.ico",
      "uninstallerIcon": "src/assets/logo.ico",
      "installerHeaderIcon": "src/assets/logo.ico"
    },
    "icon": "src/assets/logo.ico"
  },
  "icon": "src/assets/logo.ico"
}
